// ===== 天下菜单组件 =====
// Phase 1: Framer Motion → CSS transition

function TianxiaMenu(props) {
  var menuOpen = props.menuOpen;
  var setMenuOpen = props.setMenuOpen;
  var viewMode = props.viewMode;
  var onSelect = props.onSelect;
  var isMobile = props.isMobile;

  var items = ["故人", "见闻", "舆图"];

  function menuToView(item) {
    return item === "故人" ? "人物" : item;
  }

  function handleSelect(item) {
    onSelect(menuToView(item));
    setMenuOpen(false);
  }

  function isActive(item) {
    return viewMode === menuToView(item);
  }

  if (isMobile) {
    // ===== 手机端 =====
    return html`
      <div
        className=${"tianxia-panel mobile flex gap-1" +
        (menuOpen ? " open" : "")}
      >
        ${items.map(function (item) {
          return html`
            <button
              key=${item}
              onClick=${function () {
                handleSelect(item);
              }}
              className=${[
                "w-7 h-[48px] border rounded-sm flex items-center justify-center transition-colors",
                isActive(item)
                  ? "border-black/25 bg-black/5"
                  : "border-black/10 hover:bg-black/5",
              ].join(" ")}
            >
              <span
                className=${[
                  "writing-vertical-rl text-xs tracking-widest select-none transition-colors",
                  isActive(item)
                    ? "text-black/70"
                    : "text-black/30 hover:text-black/60",
                ].join(" ")}
              >
                ${item}
              </span>
            </button>
          `;
        })}
      </div>
      <button
        onClick=${function () {
          setMenuOpen(!menuOpen);
        }}
        className="w-7 h-[48px] border border-black/15 rounded-sm flex items-center justify-center hover:bg-black/5 transition-colors group shrink-0"
      >
        <span
          className="writing-vertical-rl text-xs tracking-widest text-black/40 group-hover:text-black transition-colors select-none"
        >
          天下
        </span>
      </button>
    `;
  }

  // ===== 桌面端 =====
  return html`
    <div
      className=${"tianxia-panel desktop flex gap-1" +
      (menuOpen ? " open" : "")}
    >
      ${items.map(function (item) {
        return html`
          <button
            key=${item}
            onClick=${function () {
              handleSelect(item);
            }}
            className=${[
              "w-10 h-24 border rounded-sm flex items-center justify-center transition-colors",
              isActive(item)
                ? "border-black/30 bg-black/5"
                : "border-black/10 hover:bg-black/5",
            ].join(" ")}
          >
            <span
              className=${[
                "writing-vertical-rl tracking-widest select-none transition-colors",
                isActive(item)
                  ? "text-black/80"
                  : "text-black/40 hover:text-black/70",
              ].join(" ")}
            >
              ${item}
            </span>
          </button>
        `;
      })}
    </div>
    <button
      onClick=${function () {
        setMenuOpen(!menuOpen);
      }}
      className="w-10 h-24 border border-black/20 rounded-sm flex items-center justify-center hover:bg-black/5 transition-colors group"
    >
      <span
        className="writing-vertical-rl tracking-widest text-black/60 group-hover:text-black transition-colors select-none"
      >
        天下
      </span>
    </button>
  `;
}
