// ===== 顶部信息栏组件 =====
// 忠实还原 App.tsx 第 387-514 行的布局
// 仅 TSX→HTM 语法转换，所有 className 原封不动

function StatusHeader(props) {
  var worldInfo = props.worldInfo;
  var viewMode = props.viewMode;
  var onViewChange = props.onViewChange;
  var menuOpen = props.menuOpen;
  var setMenuOpen = props.setMenuOpen;
  var menuRef = props.menuRef;
  var menuRefMobile = props.menuRefMobile;

  // 年号格式化
  var yearText = worldInfo.year;
  // 桌面版：4字时第2字后加·
  var desktopYear = yearText;
  if (yearText.length === 4) {
    desktopYear = yearText.slice(0, 2) + "\u00B7" + yearText.slice(2);
  }

  // 时间
  var timeName = worldInfo.timeName || "";
  var timeNumber = worldInfo.timeNumber || "";

  // ===== 原 App.tsx 第 387-514 行 =====
  return html`
    <!-- 原 App.tsx 388: min-h-screen p-6 md:p-12 lg:p-24 max-w-7xl mx-auto relative -->
    <!-- 该层由 app.js 的根 div 提供 -->

    <!-- 原 App.tsx 389: grid -->
    <div
      className="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-8 md:gap-12 h-full"
    >
      <!-- 原 App.tsx 391: Left Column: Year (Desktop) -->
      <div className="hidden md:flex justify-center">
        <h1
          className="writing-vertical-rl text-[120px] leading-none tracking-[0.05em] font-serif opacity-90 select-none -mt-5"
          style=${{ fontFamily: '"Liu Jian Mao Cao", serif' }}
        >
          ${desktopYear}
        </h1>
      </div>

      <!-- 原 App.tsx 401: Right Column: Content -->
      <div className="flex flex-col relative">
        <!-- 原 App.tsx 403: "天下" Button - Desktop -->
        <div
          className="hidden md:flex absolute -top-4 right-6 z-50 items-start gap-2"
          ref=${menuRef}
        >
          <${TianxiaMenu}
            menuOpen=${menuOpen}
            setMenuOpen=${setMenuOpen}
            viewMode=${viewMode}
            onSelect=${onViewChange}
            isMobile=${false}
          />
        </div>

        <!-- 原 App.tsx 450: Mobile Header: Year + Menu Button -->
        <div className="md:hidden flex justify-between items-start mb-8">
          <h1
            className="font-serif opacity-90 select-none mt-2 flex items-end gap-2 whitespace-nowrap"
          >
            <span className="text-5xl leading-none">
              ${yearText.slice(0, 2)}
            </span>
            <span className="text-xl tracking-wide opacity-70 mb-[2px]">
              ${yearText.slice(2)}
            </span>
          </h1>
          <div
            className="flex items-start gap-1 mt-2 md:hidden"
            ref=${menuRefMobile}
          >
            <${TianxiaMenu}
              menuOpen=${menuOpen}
              setMenuOpen=${setMenuOpen}
              viewMode=${viewMode}
              onSelect=${onViewChange}
              isMobile=${true}
            />
          </div>
        </div>

        <!-- 原 App.tsx 507: Date, Time, Location -->
        <div
          className="flex flex-col gap-3 text-lg md:text-xl tracking-widest opacity-80 mb-12 md:mb-16 items-center md:items-start select-none"
        >
          <div className="leading-none">${worldInfo.date}</div>
          <div className="flex gap-6 mt-2">
            <span>
              ${timeName}
              <span className="text-xs md:text-sm opacity-45 ml-1.5"
                >${timeNumber}</span
              >
            </span>
            <span>${worldInfo.location}</span>
          </div>
        </div>

        <!-- 内容插槽（原 App.tsx 516+ 的内容区域） -->
        ${props.children}
      </div>
    </div>
  `;
}
